datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Admin {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tour {
  id            String   @id @default(uuid())
  title         String
  location      String
  description   String
  duration      String
  difficulty    String
  price         Float
  seats         Int
  tourDate      DateTime
  coverImage    String
  galleryImages String   // Comma-separated list of image URLs
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Gallery {
  id        String   @id @default(uuid())
  title     String
  category  String
  image     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Enquiry {
  id        String   @id @default(uuid())
  name      String
  phone     String
  email     String
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
